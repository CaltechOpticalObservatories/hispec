#!/usr/bin/env python3
"""
HSFEI ADC Rotator Daemon

Exposes the two Newport SMC100PP rotator stages of the ADC (prism 1 & 2) as libby keywords.
"""

import argparse
import sys
import threading
from typing import Any, Dict, List, Optional

from libby import KeywordRegistry

from hispec import HispecDaemon
from hispec.driver.newport.smc100pp import StageController


def _as_float(v) -> Optional[float]:
    if v is None:
        return None
    try:
        return float(v)
    except (TypeError, ValueError):
        return None


class _Stage:
    """One SMC100PP rotator axis and the keywords it exposes."""

    def __init__(self, daemon: "AdcDaemon", spec: Dict[str, Any]):
        self.daemon = daemon
        self.stage_id = int(spec.get("stage_id", 1))
        self.units = spec.get("units", "deg")
        self._softmin = _as_float(spec.get("softmin"))
        self._softmax = _as_float(spec.get("softmax"))
        self._move_lock = threading.Lock()
        # Per the spec the suffix is the stage number (positionvalue1, ismoving2, ...)
        self.suffix = str(self.stage_id)

    @property
    def controller(self) -> StageController:
        """Convenience accessor for the daemon's shared controller."""
        return self.daemon.controller

    def register_keywords(self, registry: KeywordRegistry) -> None:
        """Add this stage's keywords to the given KeywordRegistry."""
        s = self.suffix
        registry.bool(f"isreferenced{s}",
                      getter=self.is_referenced,
                      description="ADC rotator stage is referenced (homed).")
        registry.bool(f"ismoving{s}",
                      getter=self.is_moving,
                      description="ADC rotator stage is moving.")
        registry.float(f"positionvalue{s}",
                       getter=self.get_position,
                       setter=self._set_position,
                       validator=self._check_soft_limits,
                       units=self.units,
                       description="ADC rotator stage position in degrees.")
        registry.float(f"softmin{s}",
                       getter=lambda: self._softmin,
                       units=self.units,
                       nullable=True,
                       description="ADC rotator stage software minimum position.")
        registry.float(f"softmax{s}",
                       getter=lambda: self._softmax,
                       units=self.units,
                       nullable=True,
                       description="ADC rotator stage software maximum position.")
        registry.float(f"hardmin{s}",
                       getter=lambda: self._hard_limits()[0],
                       units=self.units,
                       description="ADC rotator stage hardware minimum position.")
        registry.float(f"hardmax{s}",
                       getter=lambda: self._hard_limits()[1],
                       units=self.units,
                       description="ADC rotator stage hardware maximum position.")

    def is_referenced(self) -> bool:
        """Return True if the stage has been referenced (homed)."""
        return bool(self.controller.is_homed(self.stage_id))

    def is_moving(self) -> bool:
        """Return True if the stage is currently moving."""
        return "MOVING" in self.controller.get_state(self.stage_id)

    def get_position(self) -> Optional[float]:
        """Return the current stage position in degrees."""
        return self.controller.get_pos(self.stage_id)

    def stop(self) -> None:
        """Halt motion on this stage.
        """
        # The SMC100PP doesn't have a separate "halt" command; this will be implemented
        # once the driver supports it. For now, just log a warning.
        self.daemon.logger.warning("Halt command not implemented for stage %d", self.stage_id)

    def _hard_limits(self) -> tuple:
        limits = self.controller.get_limits()
        entry = limits.get(str(self.stage_id))
        if entry is None:
            raise RuntimeError(f"failed to read hardware limits for stage {self.stage_id}")
        return entry

    def _check_soft_limits(self, v: float) -> Optional[str]:
        if self._softmin is not None and v < self._softmin:
            return f"target {v} below softmin {self._softmin}"
        if self._softmax is not None and v > self._softmax:
            return f"target {v} above softmax {self._softmax}"
        return None

    def _set_position(self, v: float) -> None:
        with self._move_lock:
            if self.is_moving():
                raise RuntimeError("stage is already moving; halt or wait for completion")
            if not self.controller.move_abs(position=v, stage_id=self.stage_id, blocking=False):
                raise RuntimeError("controller rejected move command")


class AdcDaemon(HispecDaemon):  # pylint: disable=W0223
    """Daemon for controlling the ADC prism rotators via keywords."""

    group_id = "hsfei"

    def __init__(self):
        super().__init__()

        self.ip_address = None
        self.tcp_port = None
        self.position_tolerance = 0.01
        self.stages: List[_Stage] = []
        self.named_positions: Dict[str, List[float]] = {}
        # Two daisy-chained rotators; stage count is fixed by the ADC design.
        self.controller = StageController(num_stages=2, log=True)

    def on_start(self, _libby):
        """Called when the daemon starts - register keywords and connect."""
        # from_config populates _config after __init__, so read it here
        self.ip_address = self.get_config("hardware.ip_address")
        self.tcp_port = self.get_config("hardware.tcp_port")
        self.position_tolerance = _as_float(
            self.get_config("hardware.position_tolerance", 0.01)) or 0.01
        self.named_positions = self._config.get("named_positions", {}) or {}
        self.controller.move_rate = _as_float(
            self.get_config("hardware.move_rate")) or self.controller.move_rate
        self.stages = self._build_stages()

        self.logger.info("Starting %s daemon with %d stage(s)", self.peer_id, len(self.stages))

        for stage in self.stages:
            stage.register_keywords(self.keyword_registry)

        self.keyword_registry.bool("isconnected",
                                   getter=self.controller.is_connected,
                                   setter=self._set_connected,
                                   description="ADC rotator controller is connected.")
        self.keyword_registry.string("error",
                                     getter=self._error_string,
                                     description="ADC error string for either rotator stage.")
        self.keyword_registry.trigger("halt",
                                      action=self._halt_all,
                                      description="Halt all ADC rotator motion.")
        self.keyword_registry.bool("isreferenced",
                                   getter=lambda: all(s.is_referenced() for s in self.stages),
                                   description="Both ADC rotator stages are referenced.")
        self.keyword_registry.bool("ismoving",
                                   getter=lambda: any(s.is_moving() for s in self.stages),
                                   description="Either ADC rotator stage is moving.")
        self.keyword_registry.string("positionnamed",
                                     getter=self._current_named,
                                     setter=self._goto_named,
                                     validator=self._check_named,
                                     description="ADC named position (e.g. crossed, "
                                                 "maxdisp); 'custom' when unmatched.")

        if not (self.ip_address and self.tcp_port):
            self.logger.error("No IP address or port specified")
            return

        try:
            self._connect_hardware()
            self.logger.info("Daemon started successfully and connected to hardware")
        except Exception as e:  # pylint: disable=W0718
            self.logger.error("Failed to connect to hardware: %s", e)
            self.logger.warning("Daemon will start but hardware is not available")

    def on_stop(self, _libby=None):
        """Cleanup when the daemon shuts down."""
        self.logger.info("Shutting down %s daemon", self.peer_id)
        try:
            self.controller.disconnect()
            self.logger.info("Disconnected from ADC controller")
        except Exception as e:  # pylint: disable=W0718
            self.logger.error("Error disconnecting: %s", e)

    def _build_stages(self) -> List[_Stage]:
        stages_cfg = self._config.get("stages")
        if stages_cfg:
            return [_Stage(self, s) for s in stages_cfg]
        # Fall back to the two-stage ADC default if not enumerated in config.
        return [_Stage(self, {"stage_id": n, "units": "deg"}) for n in (1, 2)]

    def _connect_hardware(self):
        self.logger.info("Connecting to ADC controller at %s:%s",
                         self.ip_address, self.tcp_port)
        self.controller.connect(host=self.ip_address, port=int(self.tcp_port))
        if self.controller.is_connected():
            self.controller.initialize()

    def _set_connected(self, value: bool) -> None:
        if value:
            self._connect_hardware()
        else:
            self.controller.disconnect()

    def _error_string(self) -> str:
        """Combine the last-error strings from both stages."""
        try:
            parts = [f"{s.stage_id}: {self.controller.get_last_error(s.stage_id)}"
                     for s in self.stages]
            return " | ".join(parts)
        except Exception as e:  # pylint: disable=W0718
            return f"error read failed: {e}"

    def _halt_all(self) -> None:
        for stage in self.stages:
            stage.stop()

    def _check_named(self, name: str) -> Optional[str]:
        if not name:
            return "value must be a non-empty string"
        if name not in self.named_positions:
            return (f"unknown named position '{name}'; "
                    f"available: {list(self.named_positions.keys())}")
        return None

    def _current_named(self) -> str:
        """Return the named position both stages currently match, else 'custom'."""
        positions = [s.get_position() for s in self.stages]
        if any(p is None for p in positions):
            return "custom"
        for name, targets in self.named_positions.items():
            if len(targets) == len(positions) and all(
                    abs(p - float(t)) <= self.position_tolerance
                    for p, t in zip(positions, targets)):
                return name
        return "custom"

    def _goto_named(self, name: str) -> None:
        """Move both stages to the angles defined by the given named position."""
        targets = self.named_positions[name]
        if len(targets) != len(self.stages):
            raise RuntimeError(
                f"named position '{name}' has {len(targets)} values, "
                f"expected {len(self.stages)}")
        for stage, target in zip(self.stages, targets):
            stage._set_position(float(target))  # pylint: disable=W0212


def main():
    """Main entry point for the daemon."""
    parser = argparse.ArgumentParser(description='HSFEI ADC Rotator Daemon')
    parser.add_argument('-c', '--config', type=str,
                        help='Path to config file (YAML or JSON)')
    parser.add_argument('-d', '--daemon-id', type=str,
                        help='Daemon ID (required for subsystem configs with multiple daemons)')

    args = parser.parse_args()

    if not args.config:
        print("--config is required", file=sys.stderr)
        sys.exit(2)

    try:
        daemon = AdcDaemon.from_config_file(args.config, daemon_id=args.daemon_id)
        daemon.serve()
    except KeyboardInterrupt:
        print("\nDaemon interrupted by user")
        sys.exit(0)
    except Exception as e:  # pylint: disable=W0718
        print(f"Error running daemon: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == '__main__':
    main()
